---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';
import { getAllPosts, getPostBySlug, formatDate } from '@/lib/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) return Astro.redirect('/blog/');

// Convert simple markdown to HTML (headings, bold, italic, lists)
function simpleMarkdown(md: string): string {
  return md
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
    .replace(/^(\d+)\. (.+)$/gm, '<li>$2</li>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(?!<[hul])(.+)$/gm, '$1')
    .split('\n\n').map(block => {
      if (block.startsWith('<h') || block.startsWith('<ul') || block.startsWith('<ol')) return block;
      return `<p>${block}</p>`;
    }).join('\n');
}

// WordPress posts store HTML directly; hand-written posts use markdown
const bodyHtml = post.body.trim().startsWith('<') ? post.body : simpleMarkdown(post.body);
---

<BaseLayout
  title={post.meta_title ?? `${post.title} | Heidi Blondin Financial`}
  description={post.meta_desc ?? post.excerpt ?? ''}
  noindex={post.noindex}
>

  <!-- Hero -->
  <section class="bg-brand-plum py-12 lg:py-16">
    <div class="container-content max-w-3xl">
      <h1 class="font-serif text-2xl lg:text-[2rem] text-white text-balance" style="font-optical-sizing: auto; line-height: 1.2; letter-spacing: -0.01em;">{post.title}</h1>
    </div>
  </section>

  <!-- Post body -->
  <article class="bg-white section-gap">
    <div class="container-content max-w-3xl">
      <div class="prose-hbf" set:html={bodyHtml} />

      <!-- Author -->
      <div class="mt-12 pt-8 border-t border-brand-plum/10 flex items-center gap-4">
        <img src="/team/heidi-portrait.jpg" alt="Heidi Blondin" class="w-14 h-14 object-cover object-top flex-shrink-0" />
        <div>
          <div class="font-sans text-sm font-semibold text-brand-plum">{post.author}</div>
          <div class="font-sans text-xs text-brand-ink/55 mt-0.5">CFP®, EPC · Heidi Blondin Financial</div>
          {post.published_at && (
            <div class="font-sans text-xs text-brand-ink/40 mt-0.5">{formatDate(post.published_at)}</div>
          )}
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="mt-8 bg-brand-tintPlum p-5 border-l-2 border-brand-plum/30">
        <p class="font-sans text-xs text-brand-ink/55 leading-relaxed">
          This article is for general information purposes only and does not constitute personalized financial advice. Mutual funds are offered through Investia Financial Services Inc. Insurance products are offered through Heidi Blondin Financial / Qualified Financial Services. Please consult with a qualified financial advisor before making any financial decisions.
        </p>
      </div>

      {post.tags && post.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {post.tags.map(tag => (
            <span class="font-sans text-[11px] font-medium text-brand-sageDark bg-brand-tintSage px-3 py-1.5 tracking-wide uppercase">{tag}</span>
          ))}
        </div>
      )}

      <div class="mt-10">
        <a href="/blog/" class="font-sans text-sm font-medium text-brand-gold flex items-center gap-2 hover:gap-3 transition-all">
          <svg class="w-4 h-4 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          Back to all posts
        </a>
      </div>
    </div>
  </article>

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "description": post.excerpt ?? post.meta_desc,
    "author": {
      "@type": "Person",
      "name": post.author,
      "jobTitle": "CFP®, EPC",
      "worksFor": { "@type": "Organization", "name": "Heidi Blondin Financial Inc." }
    },
    "publisher": {
      "@type": "Organization",
      "name": "Heidi Blondin Financial Inc.",
      "url": "https://heidiblondin.com"
    },
    "datePublished": post.published_at,
    "dateModified": post.updated_at,
    "url": `https://heidiblondin.com/blog/${post.slug}/`
  })} />

  <CTABand heading="Found this helpful?" sub="Book a free consultation and we'll apply this thinking to your specific situation." />

</BaseLayout>
