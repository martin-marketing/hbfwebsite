---
import BaseLayout from '@/layouts/BaseLayout.astro';

const testimonials = [
  {
    quote: "Dear Heidi,\nI'd like to take this opportunity to thank you for providing exceptional service. You have guided my financial direction since 2007 and have tailored a plan to suit my budget and goals. Your knowledge, professionalism, and honest approach have allowed me to relax and trust that you have my best interests in hand.\nIt's obvious that you are passionate about helping others and as a result I have a great deal of confidence knowing that you are helping me plan for my future.\nSincerely,",
    attribution: 'A.F. – Kingston, Ontario',
  },
  {
    quote: "Dear Heidi,\nThank you for helping me put the right insurance in place to protect my family and I in the event of illness or death. I really appreciated the time you took to walk me through the many options. I learned a great deal throughout the process which allowed me to make an informed decision. In the end we put in place a nice combination of products to suit my requirements and budget. With proper coverage in place I have peace of mind knowing my family will be safe.\nThanks again for all your help!",
    attribution: 'LW – Kingston, Ontario',
  },
  {
    quote: "After my husband passed away, I found myself in need of sound financial advice. I was thrilled to have Heidi in my life to lean on. She and her team at Heidi Blondin Financial helped me make some tough decisions and develop a plan for my future. Heidi has helped me build an investment portfolio that allows me to stay invested even when news headlines cause me to think otherwise. She has taught me many valuable strategies about investing.\nHeidi has a caring and honest approach. I would whole-heartedly recommend her to anyone needing solid financial advice.\nSincerely,",
    attribution: 'O.S. – Kingston, Ontario',
  },
  {
    quote: "Heidi has been my trusted advisor and friend for several years. She and her team have provided sound financial guidance in the investment of my life savings. I am able to sleep at night knowing that they are invested according to my risk comfort levels. I also reap the rewards of various solutions that provide the most tax efficient income in my retirement.\nI would encourage anyone looking for a great Financial Advisor to call Heidi.",
    attribution: 'T.O. – Kingston, Ontario',
  },
  {
    quote: "My partner and I have worked with Heidi Blondin of Blondin Financial for almost a year. We recently retired and needed help with our financial planning and investments. We needed sound, honest and prudent advice. First and foremost was to find someone that we could trust, feel comfortable and confident with and who understood our personal needs and desires. This is Heidi. More than thrilled to have found someone that meets all of our requirements and more. We honestly feel so fortunate to have found her.",
    attribution: 'P.M. – Kingston, Ontario',
  },
  {
    quote: "It is a true pleasure to work with Heidi. She is professional, responsive and provides an excellent holistic overview to her clients to help them plan for their financial future.",
    attribution: 'K.M. – Kingston, Ontario',
  },
  {
    quote: "Heidi Blondin Financial has exceeded my expectations. Heidi is thorough and accommodating. I feel secure in knowing she has both my current and future financial interests in mind with every decision we make together.",
    attribution: 'Donna H.',
  },
  {
    quote: "Heidi Blondin Financial has skillfully managed our retirement investments and finances for years. Recently we have also consulted regarding wills and estate planning. Advice is always realistic, honest, and informative. Heidi and her team are professional, approachable, and accessible. Angela is a delightful liaison and document wizard. They keep our accounts current and competitive in this roller coaster world. Personally, Blondin Financial gives us peace of mind, which adds so much to our quality of life.",
    attribution: 'Angela M.',
  },
];
---

<BaseLayout
  title="Client Testimonials | Heidi Blondin Financial"
  description="What clients say about working with Heidi Blondin Financial. Real experiences from real Ontario families."
>

  <!-- Hero -->
  <section class="bg-brand-plum py-20 lg:py-28">
    <div class="container-content text-center">
      <p class="eyebrow-light mb-5">Client Stories</p>
      <h1 class="font-serif text-display text-white max-w-2xl mx-auto text-balance" style="font-optical-sizing: auto;">
        What our clients say
      </h1>
      <p class="font-sans text-[18px] text-white/65 mt-6 max-w-lg mx-auto">
        We measure success by the confidence our clients feel about their financial future.
      </p>
    </div>
  </section>

  <!-- Testimonials grid -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-brand-tintPlum p-8 flex flex-col">
            <div class="font-serif text-brand-gold text-5xl leading-none mb-4 select-none" style="font-optical-sizing: auto;">&ldquo;</div>
            <blockquote class="font-serif text-lg text-brand-plum leading-relaxed flex-1 mb-6" style="font-optical-sizing: auto; font-style: italic; font-variation-settings: 'SOFT' 60;">
              {t.quote.split('\n').map((line, i, arr) => (
                <Fragment>{line}{i < arr.length - 1 && <br />}</Fragment>
              ))}
            </blockquote>
            <cite class="font-sans text-xs tracking-[0.18em] uppercase text-brand-sageDark not-italic">{t.attribution}</cite>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
