---
import BaseLayout from '@/layouts/BaseLayout.astro';

const services = [
  { name: 'Retirement Savings Solutions', href: '/financial-services/retirement-savings-solutions/' },
  { name: 'Individual Pension Plans', href: '/financial-services/individual-pension-plans/' },
  { name: 'Group Retirement and Pension Plans', href: '/financial-services/group-retirement-and-pension-plans/' },
  { name: 'Education Savings Plans', href: '/financial-services/education-savings-plans/' },
  { name: 'Tax Free Savings Accounts', href: '/financial-services/tax-free-savings-accounts/' },
  { name: 'First Home Savings Accounts', href: '/financial-services/first-home-savings-accounts/' },
  { name: 'Corporate Savings', href: '/financial-services/corporate-savings/' },
  { name: 'Registered Disability Savings', href: '/financial-services/registered-disability-savings/' },
  { name: 'Estate Planning', href: '/financial-services/estate-planning/' },
  { name: 'Life Insurance', href: '/financial-services/life-insurance/' },
  { name: 'Critical Illness Plans', href: '/financial-services/critical-illness-plans/' },
  { name: 'Disability Insurance', href: '/financial-services/disability-insurance/' },
  { name: 'Guaranteed Issue Life Insurance', href: '/financial-services/guaranteed-issue-life-insurance/' },
  { name: 'Individual Health & Dental Plans', href: '/financial-services/individual-health-dental-plans/' },
  { name: 'Group Benefit Plans', href: '/financial-services/group-benefit-plans/' },
  { name: 'Long Term Care', href: '/financial-services/long-term-care/' },
  { name: 'Travel Insurance', href: '/financial-services/travel-insurance/' },
  { name: 'Charitable Giving', href: '/financial-services/charitable-giving/' },
  { name: 'Segregated Funds', href: '/financial-services/segregated-funds/' },
];
---

<BaseLayout
  title="Financial Services | Heidi Blondin Financial"
  description="Investing, insurance, and planning solutions for Ontario families. Retirement savings, life insurance, critical illness, disability, estate planning, and more."
>

  <!-- Page Header -->
  <section class="bg-brand-plum py-20 lg:py-28">
    <div class="container-content">
      <h1 class="font-serif text-display text-white max-w-2xl text-balance" style="font-optical-sizing: auto;">
        Financial Services
      </h1>
    </div>
  </section>

  <!-- Flat Service List -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map(item => (
          <li>
            <a href={item.href} class="group flex items-center gap-2 border border-brand-plum/10 px-5 py-4 hover:border-brand-plum/25 hover:shadow-sm transition-all">
              <span class="font-sans text-sm font-semibold text-brand-plum group-hover:text-brand-gold transition-colors flex-1">{item.name}</span>
              <svg class="w-3.5 h-3.5 text-brand-gold group-hover:translate-x-0.5 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-tintPlum section-gap">
    <div class="container-content text-center max-w-2xl mx-auto">
      <p class="font-sans text-[17px] text-brand-ink/80 leading-relaxed mb-8">
        If you have questions or would like more information, Contact Heidi today or ask for a quote.
      </p>
      <a href="/contact/" class="btn-primary-gold">Contact Heidi</a>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-white section-gap">
    <div class="container-content max-w-3xl mx-auto">
      <blockquote class="border-l-4 border-brand-gold pl-8">
        <p class="font-sans text-[17px] text-brand-ink/80 leading-relaxed">
          My partner and I have worked with Heidi Blondin of Blondin Financial for almost a year. We recently retired and needed help with our financial planning and investments. We needed sound, honest and prudent advice. First and foremost was to find someone that we could trust, feel comfortable and confident with and who understood our personal needs and desires. This is Heidi. More than thrilled to have found someone that meets all of our requirements and more. We honestly feel so fortunate to have found her. P.M. &ndash; Kingston, Ontario
        </p>
      </blockquote>
      <div class="mt-8 pl-8">
        <a href="/reviews/" class="font-sans text-sm font-semibold text-brand-gold hover:underline">See &amp; Write Reviews for Heidi</a>
      </div>
    </div>
  </section>

</BaseLayout>
