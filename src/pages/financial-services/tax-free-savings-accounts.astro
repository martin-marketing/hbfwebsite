---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';

const features = [
  { title: 'Completely tax-free growth', desc: 'Interest, dividends, and capital gains earned inside your TFSA are never taxed — not even when you withdraw them.' },
  { title: 'Withdraw any time', desc: 'Unlike an RRSP, there are no restrictions on when you can take money out. Spend it on anything — and your contribution room comes back the following year.' },
  { title: 'Cumulative contribution room', desc: 'If you were 18 or older in 2009, you may have up to $95,000 in available TFSA room (as of 2024). Unused room carries forward every year.' },
  { title: 'No impact on income-tested benefits', desc: 'TFSA withdrawals don\'t count as income, so they don\'t affect your eligibility for OAS, GIS, or other income-tested government programs.' },
  { title: 'Flexible investment options', desc: 'Your TFSA can hold mutual funds, GICs, ETFs, and more — not just cash. We help you invest it strategically for your goals.' },
  { title: 'Estate planning benefit', desc: 'With a named successor holder or beneficiary, your TFSA passes directly to a spouse or can avoid probate — a useful estate planning tool.' },
];
---

<BaseLayout
  title="TFSA — Tax-Free Savings Account | Heidi Blondin Financial"
  description="Grow your savings tax-free and withdraw whenever you need. Learn how TFSAs work and how to maximize your contribution room with Heidi Blondin Financial."
>

  <section class="bg-brand-plum py-20">
    <div class="container-content max-w-3xl">
      <p class="eyebrow-light mb-5">Investing</p>
      <h1 class="font-serif text-display text-white text-balance" style="font-optical-sizing: auto;">Tax-Free Savings Account (TFSA)</h1>
      <p class="font-sans text-[18px] text-white/65 mt-5 leading-relaxed">
        Every dollar you earn inside a TFSA stays yours — no tax on growth, no tax on withdrawals. It's one of the most flexible financial tools available to Canadians.
      </p>
    </div>
  </section>

  <section class="bg-white section-gap">
    <div class="container-content max-w-3xl">
      <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">More than a savings account</h2>
      <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-4">
        <p>Despite the name, a TFSA isn't just for savings — it's a registered account that can hold a full range of investments and shelter every dollar of growth from tax. You contribute with after-tax dollars, but everything that happens inside the account (growth, income, withdrawals) is completely tax-free.</p>
        <p>For many Canadians, especially those in lower tax brackets now who expect higher income in retirement, a TFSA is the smarter first priority. It also makes an excellent complement to an RRSP — the two accounts work together to cover different needs across your financial life.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-5">
        {features.map(item => (
          <div class="bg-brand-tintSage p-6">
            <h3 class="font-sans text-sm font-semibold text-brand-plum mb-2">{item.title}</h3>
            <p class="font-sans text-[13px] text-brand-ink/65 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <h2 class="font-serif text-h2 text-brand-plum mb-4" style="font-optical-sizing: auto;">Common TFSA mistakes to avoid</h2>
        <ul class="font-sans text-[16px] text-brand-ink/75 leading-relaxed space-y-3">
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold mt-0.5">01</span><span><strong class="text-brand-plum">Over-contributing:</strong> Contributing more than your available room triggers a 1% per month penalty tax. We track your room and help you stay within limits.</span></li>
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold mt-0.5">02</span><span><strong class="text-brand-plum">Holding it as cash:</strong> Many people leave their TFSA in a savings account earning minimal interest. Investing it properly can make a significant difference over time.</span></li>
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold mt-0.5">03</span><span><strong class="text-brand-plum">Withdrawing and re-contributing in the same year:</strong> Your contribution room from a withdrawal only returns on January 1 of the next calendar year.</span></li>
        </ul>
      </div>

      <div class="mt-10 bg-brand-tintPlum p-5 border-l-2 border-brand-plum/30">
        <p class="font-sans text-xs text-brand-ink/55 leading-relaxed">Mutual funds are offered through Investia Financial Services Inc. This article is for general information purposes only and does not constitute personalized financial advice. Please consult a qualified advisor before making any financial decisions.</p>
      </div>
    </div>
  </section>

  <CTABand heading="Maximize your TFSA" sub="Book a free consultation and we'll show you how to put your TFSA to work for your goals." />

</BaseLayout>
