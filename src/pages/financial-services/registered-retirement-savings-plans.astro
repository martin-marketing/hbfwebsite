---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';

const benefits = [
  { title: 'Tax deduction today', desc: 'Every dollar you contribute to your RRSP reduces your taxable income for the year — which means a bigger refund (or a smaller tax bill).' },
  { title: 'Tax-deferred growth', desc: 'Your investments grow inside the RRSP without triggering annual tax on dividends or capital gains — compounding works faster.' },
  { title: 'Spousal RRSP income splitting', desc: 'Contribute to a spousal RRSP to equalize retirement income between partners and reduce your combined tax burden in retirement.' },
  { title: 'Home Buyers\' Plan (HBP)', desc: 'Withdraw up to $60,000 from your RRSP tax-free to buy your first home — repayable over 15 years.' },
  { title: 'Lifelong Learning Plan (LLP)', desc: 'Withdraw from your RRSP to fund full-time education for yourself or your spouse — up to $10,000 per year.' },
  { title: 'Converts to RRIF at 71', desc: 'Your RRSP becomes a Registered Retirement Income Fund at age 71, providing a structured income stream in retirement.' },
];
---

<BaseLayout
  title="RRSP — Registered Retirement Savings Plan | Heidi Blondin Financial"
  description="Reduce taxes today and build retirement wealth tomorrow. Learn how RRSPs work and how to make the most of your contribution room with Heidi Blondin Financial."
>

  <section class="bg-brand-plum py-20">
    <div class="container-content max-w-3xl">
      <p class="eyebrow-light mb-5">Investing</p>
      <h1 class="font-serif text-display text-white text-balance" style="font-optical-sizing: auto;">Registered Retirement Savings Plan (RRSP)</h1>
      <p class="font-sans text-[18px] text-white/65 mt-5 leading-relaxed">
        Save for retirement and reduce your tax bill at the same time. The RRSP is one of Canada's most powerful wealth-building tools — when used strategically.
      </p>
    </div>
  </section>

  <section class="bg-white section-gap">
    <div class="container-content max-w-3xl">
      <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">How an RRSP works</h2>
      <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-4">
        <p>An RRSP lets you contribute a portion of your earned income each year and deduct those contributions from your taxable income. The investments inside your RRSP grow tax-deferred — you don't pay tax on any gains until you withdraw the money, ideally in retirement when your income (and tax rate) is lower.</p>
        <p>Your annual RRSP contribution limit is 18% of your previous year's earned income, up to a maximum set by the CRA each year. Unused room carries forward indefinitely, so if you haven't been maximizing your contributions, it's never too late to catch up.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-5">
        {benefits.map(item => (
          <div class="bg-brand-tintPlum p-6">
            <h3 class="font-sans text-sm font-semibold text-brand-plum mb-2">{item.title}</h3>
            <p class="font-sans text-[13px] text-brand-ink/65 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <h2 class="font-serif text-h2 text-brand-plum mb-4" style="font-optical-sizing: auto;">RRSP vs. TFSA — which is right for you?</h2>
        <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed">
          Both are valuable — and they serve different purposes. An RRSP gives you a tax break now; a TFSA grows tax-free forever. Many Canadians benefit from using both strategically. The right balance depends on your current income, your expected retirement income, and when you expect to need the money.
        </p>
        <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed mt-4">
          We help you figure out the right contribution split for your situation — and make sure you're not leaving any tax savings on the table.
        </p>
      </div>

      <div class="mt-10 bg-brand-tintPlum p-5 border-l-2 border-brand-plum/30">
        <p class="font-sans text-xs text-brand-ink/55 leading-relaxed">Mutual funds are offered through Investia Financial Services Inc. This article is for general information purposes only and does not constitute personalized financial advice. Please consult a qualified advisor before making any investment decisions.</p>
      </div>
    </div>
  </section>

  <CTABand heading="Make the most of your RRSP" sub="Book a free consultation and we'll look at your contribution room, tax situation, and retirement timeline together." />

</BaseLayout>
