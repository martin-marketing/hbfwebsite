              <td class="px-4 py-3 text-center">$39.60/mo</td>
              <td class="px-4 py-3 text-center">$109.51/mo</td>
              <td class="px-4 py-3 text-center">$362.25/mo</td>
            </tr>
            <tr class="bg-brand-tintPlum">
              <td class="px-4 py-3 font-medium">$1,000,000</td>
              <td class="px-4 py-3 text-center">$22.50/mo</td>
              <td class="px-4 py-3 text-center">$26.10/mo</td>
              <td class="px-4 py-3 text-center">$51.30/mo</td>
              <td class="px-4 py-3 text-center">$132.66/mo</td>
