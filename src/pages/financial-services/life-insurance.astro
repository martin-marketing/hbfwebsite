              <td class="px-4 py-3 text-center">$30.83/mo</td>
              <td class="px-4 py-3 text-center">$30.83/mo</td>
              <td class="px-4 py-3 text-center">$59.18/mo</td>
              <td class="px-4 py-3 text-center">$144.95/mo</td>
              <td class="px-4 py-3 text-center">$522.23/mo</td>
            </tr>
            <tr class="bg-brand-tintPlum">
