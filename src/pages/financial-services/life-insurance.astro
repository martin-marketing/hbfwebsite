              <td class="px-4 py-3 text-center">$22.05/mo</td>
              <td class="px-4 py-3 text-center">$40.95/mo</td>
              <td class="px-4 py-3 text-center">$97.83/mo</td>
              <td class="px-4 py-3 text-center">$349.65/mo</td>
            </tr>
            <tr class="bg-white">
