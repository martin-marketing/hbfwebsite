      <h3 class="font-sans text-base font-semibold text-brand-plum mb-3">Female, 10-year Term Insurance - Non-Smoker</h3>
      <div class="overflow-x-auto mb-8">
        <table class="w-full font-sans text-[14px] border-collapse">
          <thead>
            <tr class="bg-brand-plum text-white">
