              <th class="px-4 py-3 text-center font-semibold">Age 45</th>
              <th class="px-4 py-3 text-center font-semibold">Age 55</th>
              <th class="px-4 py-3 text-center font-semibold">Age 65</th>
            </tr>
          </thead>
          <tbody class="text-brand-ink/75">
            <tr class="bg-white">
              <td class="px-4 py-3 font-medium">$250,000</td>
              <td class="px-4 py-3 text-center">$10.58/mo</td>
