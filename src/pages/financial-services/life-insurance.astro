---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';

const types = [
  { name: 'Term Life Insurance', desc: 'Coverage for a defined period — 10, 20, or 30 years — at lower cost. Ideal when you need maximum protection during your peak income-earning years, while paying a mortgage, or raising children.' },
  { name: 'Whole Life Insurance', desc: 'Permanent coverage that never expires, with a guaranteed cash value component that grows over time. Used for estate planning, wealth transfer, and long-term financial planning.' },
  { name: 'Universal Life Insurance', desc: 'Flexible permanent coverage that combines a death benefit with an investment component. You can adjust premiums and benefit amounts as your life changes.' },
  { name: 'Life Insurance Without Medical', desc: 'Simplified or guaranteed issue policies for applicants who may not qualify for traditional coverage due to health history. Coverage amounts are typically lower, but the approval process is much simpler.' },
];
---

<BaseLayout
  title="Life Insurance | Heidi Blondin Financial"
  description="Find the right life insurance coverage for your family. Term, whole life, and universal life options explained by an independent CFP® advisor in Kingston, Ontario."
>

  <section class="bg-brand-plum py-20">
    <div class="container-content max-w-3xl">
      <p class="eyebrow-light mb-5">Insurance</p>
      <h1 class="font-serif text-display text-white text-balance" style="font-optical-sizing: auto;">Life Insurance</h1>
      <p class="font-sans text-[18px] text-white/65 mt-5 leading-relaxed">
        Life insurance isn't about you — it's about the people who depend on you. The right policy makes sure they're never left in a financially vulnerable position.
      </p>
    </div>
  </section>

  <section class="bg-white section-gap">
    <div class="container-content max-w-3xl">
      <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">What life insurance actually does</h2>
      <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-4">
        <p>At its core, life insurance replaces the income — or covers the debts and responsibilities — that your family would lose if you were no longer here. It's how you ensure a mortgage gets paid, children's education continues, and your spouse isn't forced to make financial decisions from a place of crisis.</p>
        <p>But life insurance also plays a role in estate planning, wealth transfer, business succession, and tax-efficient giving. The policy that's right for you depends on where you are in life, what you're protecting, and how long you need coverage.</p>
        <p>As independent advisors, we work with multiple insurance companies — not just one — which means we can find you better rates and more appropriate coverage than an advisor tied to a single provider.</p>
      </div>

      <div class="mt-12">
        <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">Types of life insurance</h2>
        <div class="space-y-4">
          {types.map(item => (
            <div class="border-l-2 border-brand-plum/20 pl-5 py-1">
              <h3 class="font-sans text-sm font-semibold text-brand-plum mb-2">{item.name}</h3>
              <p class="font-sans text-[14px] text-brand-ink/65 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12">
        <h2 class="font-serif text-h2 text-brand-plum mb-4" style="font-optical-sizing: auto;">How much coverage do you need?</h2>
        <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-3">
          <p>A common rule of thumb is 10× your annual income — but that's a starting point, not a plan. The right amount depends on your mortgage balance, number of dependents, other assets, and what standard of living you want to protect for your family.</p>
          <p>We walk through a proper needs analysis with every client to make sure coverage is calibrated to your actual situation — not a formula.</p>
        </div>
      </div>

      <div class="mt-10 bg-brand-tintPlum p-5 border-l-2 border-brand-plum/30">
        <p class="font-sans text-xs text-brand-ink/55 leading-relaxed">Insurance products are offered through Heidi Blondin Financial / Qualified Financial Services. This article is for general information purposes only and does not constitute personalized insurance advice. Please consult with a qualified advisor to determine what coverage is appropriate for your situation.</p>
      </div>
    </div>
  </section>

  <CTABand heading="Get a life insurance quote" sub="Book a free consultation or use our insurance quote form and we'll find you competitive coverage." />

</BaseLayout>
