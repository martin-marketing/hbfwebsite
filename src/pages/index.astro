---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getAllPosts } from '@/lib/posts';

const recentPosts = (await getAllPosts()).slice(0, 3);
---

<BaseLayout
  title="Heidi Blondin Financial - Financial Services | Mutual Funds | Insurance"
  description="At Heidi Blondin Financial, we are passionate about working with families to develop strategies to eliminate debt, protect their loved ones and live the retirement of their dreams."
>

  <!-- Hero — full photo, no crop -->
  <section>
    <img
      src="/team/team-corp367.jpeg"
      alt="The Heidi Blondin Financial team — Kingston, Ontario"
      class="w-full block"
      loading="eager"
    />
  </section>

  <!-- Headline + body copy -->
  <section class="bg-brand-tintPlum section-gap-sm">
    <div class="container-content max-w-2xl">
      <h1 class="font-serif text-display text-brand-plum mb-8 text-balance leading-[1.05]" style="font-optical-sizing: auto;">
        Are your life goals &amp; your money<br/><em class="text-brand-gold" style="font-style: italic; font-variation-settings: 'SOFT' 80;">working in harmony?</em>
      </h1>
      <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-4">
        <p>Finding the right balance between living for today and planning a financial healthy future that makes you feel excited, can seem like a daunting challenge.</p>
        <p>After all, the way you spend and invest your money can have a dramatic impact on the joy you feel in your life.</p>
        <p>But once you align your investments with the things in life that bring you happiness and inspiration, you can almost feel the worry and stress fall away.</p>
        <p>True wealth - the kind that follows you through life - is about having and doing what YOU want.</p>
        <p>Maybe that means making a difference in your community? Or ensuring your family always has what they need?</p>
        <p>Aligning your money with your life goals puts you in control.</p>
        <p>Sure, life will offer up some twists and turns.</p>
        <p>But ultimately, your financial peace of mind boils down to three key questions:</p>
      </div>
    </div>
  </section>

  <!-- Three questions band -->
  <section class="bg-brand-plum py-16 lg:py-20">
    <div class="container-content">
      <p class="eyebrow-light text-center mb-8">The questions we answer every day</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        {[
          { num: '01', q: 'Will I have enough money?' },
          { num: '02', q: 'Will my family be ok if life throws them a curveball?' },
          { num: '03', q: "Do I feel good about the way I'm investing my money?" },
        ].map(item => (
          <div class="text-center">
            <div class="font-serif text-4xl text-brand-gold/25 font-normal mb-3" style="font-optical-sizing: auto;">{item.num}</div>
            <p class="font-serif text-xl text-white leading-snug" style="font-optical-sizing: auto; font-style: italic; font-variation-settings: 'SOFT' 60;">
              &ldquo;{item.q}&rdquo;
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Body copy + office photo -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="space-y-5">
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed">
            At Heidi Blondin Financial, we've been helping professionals just like you, answer these questions in a way that allows you to spend more time enjoying life - and less time fretting about your financial future.
          </p>
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed">
            We provide one-on-one financial planning and fun interactive workshops to help you learn, grow, and succeed.
          </p>
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed">
            If you're ready to start taking control of your money, contact us to schedule a free consultation.
          </p>
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed font-medium">
            You're one phone call away from living life the way YOU want.
          </p>
          <div class="pt-2">
            <a href="tel:18558443927" class="btn-primary">Call 1 (855) 844-3927</a>
          </div>
        </div>
        <div>
          <img
            src="/office/reception.jpeg"
            alt="Heidi Blondin Financial office — Kingston, Ontario"
            class="w-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Recent blog posts -->
  {recentPosts.length > 0 && (
    <section class="bg-brand-tintSage section-gap">
      <div class="container-content">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="eyebrow mb-3">Recent Posts</p>
            <h2 class="font-serif text-h2 text-brand-plum" style="font-optical-sizing: auto;">Financial insights worth reading</h2>
          </div>
          <a href="/blog/" class="hidden md:flex items-center gap-2 font-sans text-sm font-medium text-brand-gold hover:gap-3 transition-all">
            All posts
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentPosts.map(post => (
            <BlogCard
              slug={post.slug}
              title={post.title}
              excerpt={post.excerpt}
              category={post.category}
              published_at={post.published_at}
              cover_image={post.cover_image}
            />
          ))}
        </div>
        <div class="text-center mt-10 md:hidden">
          <a href="/blog/" class="btn-ghost">All Posts</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABand />


</BaseLayout>
