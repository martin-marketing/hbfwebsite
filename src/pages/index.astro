---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TestimonialBlock from '@/components/TestimonialBlock.astro';
import CTABand from '@/components/CTABand.astro';
import BlogCard from '@/components/BlogCard.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import { getAllPosts } from '@/lib/posts';

const recentPosts = (await getAllPosts()).slice(0, 3);

const services = [
  {
    category: 'Investing',
    icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
    items: ['RRSP & Retirement Savings', 'Tax-Free Savings Accounts (TFSA)', 'First Home Savings Account (FHSA)', 'Education Savings (RESP)', 'Segregated Funds'],
    href: '/financial-services/investments/',
  },
  {
    category: 'Insurance',
    icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
    items: ['Life Insurance', 'Critical Illness Insurance', 'Disability Insurance', 'Combination Insurance', 'Travel & Group Benefits'],
    href: '/financial-services/insurance/',
  },
  {
    category: 'Planning',
    icon: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z',
    items: ['Estate Planning', 'Retirement Income Planning', 'Charitable Giving', 'Powers of Attorney', 'Executor Guidance'],
    href: '/financial-services/estate-planning/',
  },
];

const faqItems = [
  { q: 'What areas of Ontario does Heidi Blondin serve?', a: 'Heidi Blondin Financial serves clients throughout Ontario, with an office in Kingston. We work with families and individuals across the province via in-person and virtual meetings.' },
  { q: 'What is Investia Financial Services Inc.?', a: 'Investia Financial Services Inc. is a wholly-owned subsidiary of iA Financial Group and one of Canada\'s leading mutual fund dealers. Heidi offers mutual funds and approved exempt market products through Investia. Investia is a member of CIRO.' },
  { q: 'Is there a cost for the initial consultation?', a: 'Your first consultation is complimentary and carries no obligation. It\'s a conversation — we want to understand your situation before recommending anything.' },
  { q: 'How do I get started?', a: 'Use our contact form or call 1-855-844-3927. After we connect and determine it\'s a good fit, Heidi will schedule an in-depth planning meeting.' },
];
---

<BaseLayout
  title="Heidi Blondin Financial Inc. | CFP® · Kingston, Ontario"
  description="Certified Financial Planner serving Ontario families since 2007. Mutual funds through Investia Financial Services Inc. Retirement, insurance, estate planning. Kingston, ON."
>

  <!-- Hero -->
  <section class="bg-brand-tintPlum overflow-hidden">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 min-h-[580px] items-stretch">

        <!-- Text side -->
        <div class="flex flex-col justify-center py-20 pr-0 lg:pr-16">
          <p class="eyebrow mb-6">Heidi Blondin Financial · Kingston, ON</p>
          <h1 class="font-serif text-display text-brand-plum mb-6 text-balance leading-[1.05]" style="font-optical-sizing: auto;">
            Your money, <em class="text-brand-gold" style="font-style: italic; font-variation-settings: 'SOFT' 80;">in harmony</em><br/>with the life you<br/>actually want to live.
          </h1>
          <p class="font-sans text-[18px] text-brand-plumMid leading-relaxed max-w-lg mb-10">
            For over 17 years, Heidi Blondin CFP® has helped Ontario families eliminate debt, protect what matters, and build retirements they actually look forward to.
          </p>
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="/contact/" class="btn-primary">Schedule a Free Consultation</a>
            <a href="tel:18558443927" class="font-sans text-sm font-medium text-brand-plumMid hover:text-brand-plum transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z"/></svg>
              1-855-844-3927
            </a>
          </div>
          <div class="mt-10 pt-8 border-t border-brand-plum/12 flex items-center gap-8">
            <div class="text-center">
              <div class="font-serif text-2xl text-brand-plum font-normal" style="font-optical-sizing: auto;">17+</div>
              <div class="font-sans text-[11px] text-brand-ink/50 tracking-wide">Years Experience</div>
            </div>
            <div class="w-px h-8 bg-brand-plum/15"></div>
            <div class="text-center">
              <div class="font-serif text-2xl text-brand-plum font-normal" style="font-optical-sizing: auto;">CFP®</div>
              <div class="font-sans text-[11px] text-brand-ink/50 tracking-wide">Certified Planner</div>
            </div>
            <div class="w-px h-8 bg-brand-plum/15"></div>
            <div class="text-center">
              <div class="font-serif text-2xl text-brand-plum font-normal" style="font-optical-sizing: auto;">EPC</div>
              <div class="font-sans text-[11px] text-brand-ink/50 tracking-wide">Elder Planning</div>
            </div>
          </div>
        </div>

        <!-- Photo side -->
        <div class="relative hidden lg:block">
          <div class="absolute inset-0 overflow-hidden">
            <img
              src="/team/heidi-portrait.jpg"
              alt="Heidi Blondin, CFP® — Certified Financial Planner, Kingston Ontario"
              class="w-full h-full object-cover object-center"
              loading="eager"
            />
            <!-- Gradient fade into section bg -->
            <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-brand-tintPlum to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three questions band -->
  <section class="bg-brand-plum py-16 lg:py-20">
    <div class="container-content">
      <p class="eyebrow-light text-center mb-8">The questions we answer every day</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        {[
          { num: '01', q: 'Will I have enough money?' },
          { num: '02', q: 'Will my family be okay if life throws them a curveball?' },
          { num: '03', q: 'Do I feel good about the way I\'m investing my money?' },
        ].map(item => (
          <div class="text-center">
            <div class="font-serif text-4xl text-brand-gold/25 font-normal mb-3" style="font-optical-sizing: auto;">{item.num}</div>
            <p class="font-serif text-xl text-white leading-snug" style="font-optical-sizing: auto; font-style: italic; font-variation-settings: 'SOFT' 60;">
              &ldquo;{item.q}&rdquo;
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="text-center mb-14">
        <p class="eyebrow mb-4">How We Can Help</p>
        <h2 class="font-serif text-h2 text-brand-plum text-balance" style="font-optical-sizing: auto;">
          Comprehensive financial guidance<br/>for Ontario families
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map(svc => (
          <div class="border border-brand-plum/10 p-8 group hover:border-brand-plum/25 hover:shadow-sm transition-all">
            <div class="w-10 h-10 bg-brand-tintSage flex items-center justify-center mb-6">
              <svg class="w-5 h-5 text-brand-sageDark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={svc.icon} />
              </svg>
            </div>
            <h3 class="font-serif text-xl text-brand-plum mb-4 group-hover:text-brand-gold transition-colors" style="font-optical-sizing: auto;">{svc.category}</h3>
            <ul class="space-y-2 mb-6">
              {svc.items.map(item => (
                <li class="flex items-center gap-2 font-sans text-sm text-brand-ink/70">
                  <span class="w-1 h-1 rounded-full bg-brand-gold flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={svc.href} class="font-sans text-[13px] font-medium text-brand-gold flex items-center gap-1.5 hover:gap-2.5 transition-all">
              Explore {svc.category}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/financial-services/" class="btn-ghost">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <TestimonialBlock
    quote="Heidi has been my trusted advisor and friend for several years. She and her team have provided sound financial guidance in the investment of my life savings."
    attribution="T.O. · Kingston, Ontario"
  />

  <!-- Process / How it works -->
  <section class="bg-brand-tintPlum section-gap">
    <div class="container-content">
      <div class="text-center mb-14">
        <p class="eyebrow mb-4">Our Process</p>
        <h2 class="font-serif text-h2 text-brand-plum text-balance" style="font-optical-sizing: auto;">Simple, transparent, personal</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { num: '1', title: 'Connect', body: "Reach out by phone or form. We'll have a brief conversation to understand your situation and confirm it's a good fit." },
          { num: '2', title: 'Discover', body: 'A deeper planning meeting to map your goals, review your current assets, and understand what keeps you up at night.' },
          { num: '3', title: 'Plan', body: 'Heidi creates a customized financial plan — investments, insurance, and retirement strategy — built around your life, not a template.' },
          { num: '4', title: 'Grow Together', body: 'Ongoing reviews and proactive updates as your life changes. You have a direct line to Heidi and her team, always.' },
        ].map(step => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-brand-plum text-white font-serif text-xl flex items-center justify-center mx-auto mb-5" style="font-optical-sizing: auto;">{step.num}</div>
            <h3 class="font-serif text-lg text-brand-plum mb-3" style="font-optical-sizing: auto;">{step.title}</h3>
            <p class="font-sans text-sm text-brand-ink/65 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team preview -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="relative">
          <img
            src="/team/team-formal.jpg"
            alt="The Heidi Blondin Financial team"
            class="w-full aspect-[4/3] object-cover object-top"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -right-4 bg-brand-plum px-6 py-4 hidden lg:block">
            <div class="font-serif text-white text-sm italic" style="font-optical-sizing: auto;">&ldquo;Locally owned. Genuinely invested in you.&rdquo;</div>
          </div>
        </div>
        <div>
          <p class="eyebrow mb-5">About Our Team</p>
          <h2 class="font-serif text-h2 text-brand-plum mb-6 text-balance" style="font-optical-sizing: auto;">
            Real people. Real advice. <em style="font-style: italic; font-variation-settings: 'SOFT' 80;">Real relationships.</em>
          </h2>
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed mb-5">
            Heidi Blondin Financial is a locally owned, independent practice based in Kingston, Ontario. Heidi and her team have been serving Ontario families through every market cycle, every life stage, and every curveball since 2007.
          </p>
          <p class="font-sans text-[17px] text-brand-ink/75 leading-relaxed mb-8">
            We believe financial planning is personal. No templates, no one-size-fits-all solutions. Just honest advice built around your life and your goals.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/heidi/" class="btn-primary">Meet the Team</a>
            <a href="/testimonials/" class="btn-ghost">Read Client Stories</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Second testimonial -->
  <TestimonialBlock
    quote="I can't thank Heidi and her team enough for their constant support. I first came to Heidi when I was in great debt — she was very positive and encouraging. I followed her advice completely and I am now financially on track."
    attribution="D.R. · Ontario"
  />

  <!-- Recent blog posts -->
  {recentPosts.length > 0 && (
    <section class="bg-brand-tintSage section-gap">
      <div class="container-content">
        <div class="flex items-end justify-between mb-12">
          <div>
            <p class="eyebrow mb-3">From the Blog</p>
            <h2 class="font-serif text-h2 text-brand-plum" style="font-optical-sizing: auto;">Financial insights worth reading</h2>
          </div>
          <a href="/blog/" class="hidden md:flex items-center gap-2 font-sans text-sm font-medium text-brand-gold hover:gap-3 transition-all">
            All posts
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentPosts.map(post => (
            <BlogCard
              slug={post.slug}
              title={post.title}
              excerpt={post.excerpt}
              category={post.category}
              published_at={post.published_at}
              cover_image={post.cover_image}
            />
          ))}
        </div>
        <div class="text-center mt-10 md:hidden">
          <a href="/blog/" class="btn-ghost">All Posts</a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <FAQAccordion items={faqItems} heading="Questions about working with us" />

  <!-- CTA -->
  <CTABand />

</BaseLayout>
