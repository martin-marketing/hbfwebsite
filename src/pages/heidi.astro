---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';
import TestimonialBlock from '@/components/TestimonialBlock.astro';

const team = [
  {
    name: 'Heidi Blondin',
    title: 'Founder, CFP®, EPC',
    photo: '/team/heidi-portrait.jpg',
    bio: 'Heidi has been in the financial services industry since 2007 and founded Heidi Blondin Financial Inc. in 2013. She holds the Certified Financial Planner (CFP®) and Elder Planning Counselor (EPC) designations. Heidi\'s approach is deeply personal — she believes financial planning should align your money with the life you actually want to live. Mutual funds are offered through Investia Financial Services Inc.',
    href: null,
  },
  {
    name: 'Joanne Charron',
    title: 'Insurance Advisor',
    photo: '/team/joanne-portrait.jpg',
    bio: 'Joanne brings warmth and expertise to every client interaction. A licensed insurance advisor, she specializes in life, critical illness, and disability insurance — helping families protect what matters most. Insurance products are offered through Heidi Blondin Financial / Qualified Financial Services.',
    interests: [
      { label: 'Fishing', photo: '/team/joanne-fishing.jpg' },
      { label: 'Motorcycling', photo: '/team/joanne-motorcycle.jpg' },
      { label: 'Woodworking', photo: '/team/joanne-woodworking.jpg' },
    ],
    href: '/joanne/',
  },
  {
    name: 'Jack Blondin',
    title: 'Financial Advisor',
    photo: '/team/jack-portrait.jpg',
    bio: 'Jack joined the practice with a passion for helping the next generation of Ontario families build a strong financial foundation. He brings fresh perspective and genuine care to every client relationship.',
    familyPhoto: '/team/jack-family.jpg',
    familyCaption: 'Jack with his family',
    href: '/jack/',
  },
  {
    name: 'Angela McCann',
    title: 'Licensed Assistant',
    photo: '/team/angela-portrait.jpg',
    bio: 'Angela is the organizational backbone of the practice. Licensed and detail-oriented, she ensures every client interaction is smooth, timely, and accurate. She\'s often the first friendly voice you\'ll hear when you call.',
    href: '/angela/',
  },
];
---

<BaseLayout
  title="About Heidi Blondin Financial | CFP® Kingston Ontario"
  description="Meet Heidi Blondin, CFP®, EPC, and the team behind Heidi Blondin Financial Inc. Serving Ontario families from Kingston since 2007."
>

  <!-- Page hero -->
  <section class="bg-brand-plum py-20 lg:py-28">
    <div class="container-content">
      <p class="eyebrow-light mb-5">About Us</p>
      <h1 class="font-serif text-display text-white max-w-2xl text-balance" style="font-optical-sizing: auto;">
        Locally owned. Genuinely invested in <em style="font-style: italic; font-variation-settings: 'SOFT' 80;">you.</em>
      </h1>
      <p class="font-sans text-[18px] text-white/70 mt-6 max-w-xl leading-relaxed">
        Heidi Blondin Financial has been helping Ontario families build financial security since 2007. We're a tight-knit team with deep roots in Kingston and a long-term commitment to every client we serve.
      </p>
    </div>
  </section>

  <!-- Heidi's bio -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="relative">
          <img
            src="/team/heidi-portrait.jpg"
            alt="Heidi Blondin, CFP®, EPC — Founder, Heidi Blondin Financial"
            class="w-full aspect-[3/4] object-cover object-top"
            loading="lazy"
          />
        </div>
        <div class="lg:pt-4">
          <p class="eyebrow mb-4">About Heidi</p>
          <h2 class="font-serif text-h2 text-brand-plum mb-6 text-balance" style="font-optical-sizing: auto;">
            Heidi Blondin, BA, CFP®, EPC
          </h2>
          <div class="space-y-5 font-sans text-[17px] text-brand-ink/75 leading-relaxed">
            <p>Heidi has been in financial services since 2007, and founded Heidi Blondin Financial Inc. in Kingston in 2013. She holds the Certified Financial Planner (CFP®) designation — Canada's gold standard in financial planning — and the Elder Planning Counselor (EPC) designation, reflecting her commitment to clients navigating retirement and estate transitions.</p>
            <p>Her philosophy is straightforward: financial planning should align your money with the life you actually want to live. That means understanding your goals before recommending any product, listening more than talking, and building a plan you can actually stick to.</p>
            <p>Heidi offers mutual funds through Investia Financial Services Inc., a wholly-owned subsidiary of iA Financial Group and a member of CIRO. Insurance products are offered through Heidi Blondin Financial / Qualified Financial Services MGA.</p>
            <p>She lives in Kingston with her family and is deeply invested in the community she serves.</p>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="bg-brand-tintPlum font-sans text-xs font-medium text-brand-plum px-4 py-2 tracking-wide">CFP® Certified Financial Planner</span>
            <span class="bg-brand-tintPlum font-sans text-xs font-medium text-brand-plum px-4 py-2 tracking-wide">EPC Elder Planning Counselor</span>
            <span class="bg-brand-tintSage font-sans text-xs font-medium text-brand-sageDark px-4 py-2 tracking-wide">Investia Financial Services Inc.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="bg-brand-tintPlum section-gap">
    <div class="container-content">
      <div class="text-center mb-14">
        <p class="eyebrow mb-4">Why Choose Us</p>
        <h2 class="font-serif text-h2 text-brand-plum text-balance" style="font-optical-sizing: auto;">
          What makes us different
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: 'Independent & Local',
            icon: 'M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z',
            body: 'We\'re a Kingston-based, locally owned practice. We\'re not a branch of a national chain. When you call, you reach us — people who know you by name and understand your situation.',
          },
          {
            title: 'Compliance-First',
            icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
            body: 'Regulated by CIRO through Investia Financial Services Inc. We take compliance seriously — every recommendation is made within the regulatory framework that protects Ontario investors.',
          },
          {
            title: 'Long-Term Relationships',
            icon: 'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
            body: 'We measure our success by the longevity of client relationships, not the volume of transactions. Many of our clients have been with us for more than a decade — and they\'ve brought their kids and their parents.',
          },
        ].map(item => (
          <div class="bg-white p-8">
            <div class="w-10 h-10 bg-brand-tintSage flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-brand-sageDark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-serif text-xl text-brand-plum mb-3" style="font-optical-sizing: auto;">{item.title}</h3>
            <p class="font-sans text-sm text-brand-ink/70 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team grid -->
  <section class="bg-white section-gap">
    <div class="container-content">
      <div class="text-center mb-14">
        <p class="eyebrow mb-4">The Team</p>
        <h2 class="font-serif text-h2 text-brand-plum" style="font-optical-sizing: auto;">People you can count on</h2>
      </div>

      <div class="space-y-16">
        {team.map((member, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start ${i % 2 === 1 ? 'lg:grid-flow-col-dense' : ''}`}>
            <div class={i % 2 === 1 ? 'lg:col-start-2' : ''}>
              <img
                src={member.photo}
                alt={`${member.name} — ${member.title}`}
                class="w-full aspect-[3/4] object-cover object-top"
                loading="lazy"
              />
            </div>
            <div class={`flex flex-col justify-center ${i % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
              <h3 class="font-serif text-h3 text-brand-plum mb-1" style="font-optical-sizing: auto;">{member.name}</h3>
              <p class="eyebrow-sage mb-5">{member.title}</p>
              <p class="font-sans text-[16px] text-brand-ink/75 leading-relaxed mb-6">{member.bio}</p>

              {/* Joanne's personal interests */}
              {member.interests && (
                <div class="mb-6">
                  <p class="font-sans text-xs font-semibold text-brand-sageDark tracking-wide uppercase mb-3">Off the clock</p>
                  <div class="grid grid-cols-3 gap-3">
                    {member.interests.map(interest => (
                      <div>
                        <img src={interest.photo} alt={interest.label} class="w-full aspect-square object-cover" loading="lazy" />
                        <p class="font-sans text-[11px] text-brand-ink/50 mt-1 text-center">{interest.label}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Jack's family photo */}
              {member.familyPhoto && (
                <div class="mb-6">
                  <img src={member.familyPhoto} alt={member.familyCaption} class="w-full aspect-video object-cover" loading="lazy" />
                  <p class="font-sans text-[11px] text-brand-ink/50 mt-1">{member.familyCaption}</p>
                </div>
              )}
            </div>
          </div>
        ))}

        <!-- John — team only, no profile page -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <div>
            <img
              src="/team/john-portrait.jpg"
              alt="John Blondin — Operations Manager"
              class="w-full aspect-[3/4] object-cover object-top"
              loading="lazy"
            />
          </div>
          <div>
            <h3 class="font-serif text-h3 text-brand-plum mb-1" style="font-optical-sizing: auto;">John Blondin</h3>
            <p class="eyebrow-sage mb-5">Operations Manager</p>
            <p class="font-sans text-[16px] text-brand-ink/75 leading-relaxed">
              John keeps the practice running smoothly behind the scenes. As Operations Manager, he ensures that every client experience is seamless, from first contact through to ongoing service.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team photo -->
  <section class="bg-brand-tintPlum section-gap-sm">
    <div class="container-content">
      <img
        src="/team/team-casual.jpg"
        alt="The Heidi Blondin Financial team"
        class="w-full max-h-[500px] object-cover object-top"
        loading="lazy"
      />
    </div>
  </section>

  <TestimonialBlock
    quote="Heidi is a true professional who I feel actually cares about my financial wellbeing. She explains everything clearly and always has time for my questions. I wouldn't trust anyone else with my retirement."
    attribution="M.K. · Kingston, Ontario"
  />

  <CTABand heading="Ready to meet the team?" sub="Schedule a free consultation and let's see if we're a good fit." />

</BaseLayout>
