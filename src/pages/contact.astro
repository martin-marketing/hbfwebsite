---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';
---

<BaseLayout
  title="Contact Heidi Blondin Financial | Kingston, Ontario"
  description="Contact Heidi Blondin Financial Services - Kingston - Belleville. 855 - 844 - 3927 (Toll Free)"
>

  <!-- Page header -->
  <section class="bg-brand-plum py-16">
    <div class="container-content">
      <h1 class="font-serif text-display text-white" style="font-optical-sizing: auto;">
        Contact
      </h1>
    </div>
  </section>

  <!-- Contact content -->
  <section class="bg-brand-tintPlum section-gap">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Left: form + contact info -->
        <div>
          <ContactForm heading="Contact Heidi" />

          <div class="mt-12 font-sans text-sm text-brand-ink/75 leading-relaxed space-y-4">
            <div>
              <p class="font-semibold text-brand-plum">Contact</p>
              <p class="font-medium text-brand-plum">Heidi Blondin Financial Inc.</p>
              <p><a href="tel:6138872726" class="text-brand-plum hover:text-brand-gold transition-colors">613.887.2726</a> (Heidi)</p>
              <p><a href="tel:6138179641" class="text-brand-plum hover:text-brand-gold transition-colors">613.817.9641</a> (Angela &ndash; Heidi&rsquo;s Assistant) <a href="mailto:hbadmin@heidiblondin.com" class="text-brand-gold hover:text-amber-700 transition-colors">hbadmin@heidiblondin.com</a></p>
              <p><a href="tel:8558443927" class="text-brand-plum hover:text-brand-gold transition-colors">855.844.3927</a> (Toll Free)</p>
            </div>
            <div>
              <p class="font-medium text-brand-plum">Kingston Office</p>
              <address class="not-italic">
                785 Midpark Drive, Suite 100<br />
                Kingston, ON&nbsp;&nbsp;K7M 7G3
              </address>
            </div>
          </div>
        </div>

        <!-- Right: photo -->
        <div class="lg:sticky lg:top-8">
          <img
            src="/office/contact.jpeg"
            alt="Heidi Blondin Financial office — Kingston, Ontario"
            class="w-full"
            loading="eager"
          />
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
