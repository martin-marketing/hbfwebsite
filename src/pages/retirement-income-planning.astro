---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABand from '@/components/CTABand.astro';

const sources = [
  { name: 'Canada Pension Plan (CPP)', desc: 'When you start CPP matters — taking it at 60 vs. 70 can mean a difference of over 60% in your monthly benefit. We model the optimal start date for your situation.' },
  { name: 'Old Age Security (OAS)', desc: 'OAS begins at 65 (or 70 if deferred for a 36% increase) and may be reduced by the OAS clawback if your income exceeds the threshold. We plan to minimize or avoid the clawback.' },
  { name: 'Registered accounts (RRSP/RRIF)', desc: 'Your RRSP converts to a RRIF at 71 with mandatory minimum withdrawals. The order and timing of RRSP drawdowns can significantly reduce lifetime taxes paid.' },
  { name: 'Tax-Free Savings Account (TFSA)', desc: "TFSA withdrawals don't count as income — they're invisible to the CRA for OAS clawback and GIS eligibility. Used strategically, TFSAs can fund significant retirement spending tax-free." },
  { name: 'Defined benefit or workplace pension', desc: 'If you have a DB pension, it integrates with government benefits in important ways. We model the combined income to find the most efficient strategy.' },
  { name: 'Non-registered savings', desc: 'Capital gains, dividends, and interest from non-registered accounts all affect your income picture. We help sequence withdrawals to minimize annual tax.' },
];
---

<BaseLayout
  title="Retirement Income Planning | Heidi Blondin Financial"
  description="Turn your savings into reliable income. CPP timing, RRIF drawdowns, OAS optimization, and TFSA strategy for Ontario retirees — Heidi Blondin Financial, Kingston."
>

  <section class="bg-brand-plum py-20">
    <div class="container-content max-w-3xl">
      <p class="eyebrow-light mb-5">Planning</p>
      <h1 class="font-serif text-display text-white text-balance" style="font-optical-sizing: auto;">Retirement Income Planning</h1>
      <p class="font-sans text-[18px] text-white/65 mt-5 leading-relaxed">
        Saving for retirement is one challenge. Turning those savings into reliable, tax-efficient income that lasts is another. We help you build a retirement income plan that works for the life you've built.
      </p>
    </div>
  </section>

  <section class="bg-white section-gap">
    <div class="container-content max-w-3xl">
      <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">Retirement income is more complex than it looks</h2>
      <div class="font-sans text-[17px] text-brand-ink/75 leading-relaxed space-y-4">
        <p>Most Canadians have multiple potential income sources in retirement — and the decisions you make about when to start each one, and in what order to draw from them, can mean the difference of tens of thousands of dollars in lifetime taxes paid.</p>
        <p>A good retirement income plan coordinates all of these sources deliberately. It accounts for your spending needs, your tax situation, your spouse's income (if applicable), and the sequence of withdrawals across your accounts — not just whether you have "enough" saved.</p>
      </div>

      <div class="mt-12">
        <h2 class="font-serif text-h2 text-brand-plum mb-6" style="font-optical-sizing: auto;">Your retirement income sources</h2>
        <div class="space-y-4">
          {sources.map(item => (
            <div class="border-l-2 border-brand-gold/40 pl-5 py-2">
              <h3 class="font-sans text-sm font-semibold text-brand-plum mb-1.5">{item.name}</h3>
              <p class="font-sans text-[14px] text-brand-ink/65 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12 bg-brand-tintPlum p-7">
        <h3 class="font-serif text-lg text-brand-plum mb-3" style="font-optical-sizing: auto;">The three retirement income questions we answer together</h3>
        <ul class="font-sans text-[15px] text-brand-ink/70 space-y-3">
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold">1</span><span><strong class="text-brand-plum">How much will I have?</strong> — A projection of all income sources, indexed to inflation, across your expected retirement horizon.</span></li>
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold">2</span><span><strong class="text-brand-plum">Will it be enough?</strong> — A spending needs analysis that accounts for the life you want to live, healthcare costs as you age, and contingencies.</span></li>
          <li class="flex items-start gap-3"><span class="text-brand-gold font-bold">3</span><span><strong class="text-brand-plum">How do I make it last?</strong> — A sustainable drawdown strategy that minimizes taxes, preserves flexibility, and adapts as your life changes.</span></li>
        </ul>
      </div>

      <div class="mt-10 bg-brand-tintPlum p-5 border-l-2 border-brand-plum/30">
        <p class="font-sans text-xs text-brand-ink/55 leading-relaxed">Mutual funds are offered through Investia Financial Services Inc. This article is for general information purposes only and does not constitute personalized financial advice. CPP, OAS, and tax rules are subject to change. Please consult a qualified advisor before making any retirement income decisions.</p>
      </div>
    </div>
  </section>

  <CTABand heading="Build your retirement income plan" sub="Book a free consultation and we'll model your income sources and help you create a plan you can count on." />

</BaseLayout>
