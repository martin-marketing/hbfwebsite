          <!-- Social media -->
          <div class="mt-6 flex items-center gap-4">
            <a href="https://www.facebook.com/HeidiBlondinFinancial" target="_blank" rel="noopener" aria-label="Facebook" class="text-white/50 hover:text-white transition-colors">
