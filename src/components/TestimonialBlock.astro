---
interface Props {
  quote: string;
  attribution: string;
  compact?: boolean;
}
const { quote, attribution, compact = false } = Astro.props;
---

{compact ? (
  <div class="bg-brand-tintPlum px-8 py-8 rounded-none">
    <div class="quote-mark"></div>
    <blockquote class="font-serif text-xl text-brand-plum leading-relaxed mb-4" style="font-optical-sizing: auto; font-style: italic; font-variation-settings: 'SOFT' 60;">
      {quote}
    </blockquote>
    <cite class="font-sans text-xs tracking-[0.18em] uppercase text-brand-sageDark not-italic">{attribution}</cite>
  </div>
) : (
  <section class="bg-brand-plumDark py-20 lg:py-28 relative overflow-hidden">
    <!-- Subtle decorative ring -->
    <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none">
      <div class="w-[600px] h-[600px] rounded-full border border-white"></div>
    </div>
    <div class="container-content text-center relative">
      <div class="font-serif text-brand-gold text-7xl leading-none mb-4 select-none" style="font-optical-sizing: auto;">&ldquo;</div>
      <blockquote class="font-serif text-white/90 max-w-3xl mx-auto mb-6 leading-relaxed" style={`font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-optical-sizing: auto; font-style: italic; font-variation-settings: 'SOFT' 60;`}>
        {quote}
      </blockquote>
      <cite class="font-sans text-xs tracking-[0.2em] uppercase text-white/45 not-italic">{attribution}</cite>
    </div>
  </section>
)}
