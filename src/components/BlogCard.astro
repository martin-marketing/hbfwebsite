---
import { formatDate } from '@/lib/posts';
interface Props {
  slug: string;
  title: string;
  excerpt: string | null;
  category: string | null;
  published_at: string;
  cover_image?: string | null;
}
const { slug, title, excerpt, category, published_at, cover_image } = Astro.props;
---

<article class="group flex flex-col bg-white border border-brand-plum/8 hover:border-brand-plum/20 transition-colors">
  {cover_image && (
    <div class="aspect-[16/9] overflow-hidden">
      <img src={cover_image} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
    </div>
  )}
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-3 mb-3">
      {category && (
        <span class="eyebrow-sage text-[10px]">{category}</span>
      )}
      <span class="font-sans text-[11px] text-brand-ink/40">{formatDate(published_at)}</span>
    </div>
    <h3 class="font-serif text-xl text-brand-plum mb-3 leading-snug group-hover:text-brand-gold transition-colors flex-1" style="font-optical-sizing: auto;">
      <a href={`/blog/${slug}/`} class="stretched-link">{title}</a>
    </h3>
    {excerpt && (
      <p class="font-sans text-sm text-brand-ink/65 leading-relaxed mb-4 line-clamp-3">{excerpt}</p>
    )}
    <div class="flex items-center gap-1 font-sans text-xs font-medium text-brand-gold group-hover:gap-2 transition-all">
      Read more
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
    </div>
  </div>
</article>
