---
interface Props {
  heading?: string;
  sub?: string;
  cta?: string;
  href?: string;
  phone?: boolean;
}
const {
  heading = 'Ready to get started?',
  sub = 'Schedule a free, no-obligation consultation and let\'s talk about where you are and where you want to be.',
  cta = 'Schedule a Free Consultation',
  href = '/contact/',
  phone = true,
} = Astro.props;
---

<section class="bg-brand-plum py-16 lg:py-20">
  <div class="container-content text-center">
    <h2 class="font-serif text-h2 text-white mb-4 text-balance" style="font-optical-sizing: auto;">
      {heading}
    </h2>
    {sub && <p class="font-sans text-base text-white/70 max-w-xl mx-auto mb-8">{sub}</p>}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={href} class="btn-ghost-light">{cta}</a>
      {phone && (
        <a href="tel:18558443927" class="font-sans text-sm text-white/70 hover:text-white transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z"/></svg>
          Or call 1-855-844-3927
        </a>
      )}
    </div>
  </div>
</section>
